{
  "name": "webhook-service",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env src/app.js",
    "dev": "node --env-file=.env --watch src/app.js",
    "worker": "node --env-file=.env src/workers/webhookWorker.js",
    "dev:worker": "node --env-file=.env --watch src/workers/webhookWorker.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:worker\"",
    "seed": "node --env-file=.env src/seeders/seed.js",
    "seed:clear": "node --env-file=.env src/seeders/seed.js clear"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.15.1",
    "bullmq": "^5.74.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "mongoose": "^9.4.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  }
}